# notes-manager personal configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Extra keywords beyond default Fortinet product names (comma-separated)
NM_EXTRA_KEYWORDS=smart ticket,smartticket

# People to search for (comma-separated full names, case-insensitive)
NM_PEOPLE=jane doe,john smith

# Company or account names (comma-separated)
NM_ACCOUNTS=acme corp,globex

# Optional: override the Anthropic API key here instead of exporting in shell
# ANTHROPIC_API_KEY=sk-ant-...
